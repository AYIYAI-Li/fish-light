.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1000;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #1a73e8;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  display: block;
}

.tab-img {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
  display: block;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #6A6359;
  transition: color 0.3s ease;
}

.tab-item.active .tab-text {
  color: black;
  font-weight: 600;
}

.tab-item:active {
  transform: scale(0.95);
} 