.page-container {
  padding: 24rpx;
  background-color: #F4F0E4;
  min-height: 100vh;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-item {
  background-color: #F4F0E4;
  border-radius: 16rpx;
  padding: 24rpx;
}

.post-content {
  font-size: 28rpx;
  color: #585753;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.post-image {
  width: 120rpx;
  height: 100rpx;
  border-radius: 8rpx;
  object-fit: cover;
  background: #f0f0f0;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-date {
  font-size: 24rpx;
  color: #585753;
}

.delete-btn {
  margin: 0;
  background-color: #D1A777;
}


.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #585753;
  margin-top: 24rpx;
}
