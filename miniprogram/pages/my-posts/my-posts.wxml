<view class="page-container">
  <block wx:if="{{posts.length > 0}}">
    <view class="post-list">
      <view class="post-item" wx:for="{{posts}}" wx:key="_id">
        <view class="post-content">{{item.content}}</view>
        <block wx:if="{{item.images && item.images.length}}">
          <view class="post-images">
            <block wx:for="{{item.images}}" wx:for-item="img" wx:key="*this">
              <image class="post-image" src="{{img}}" mode="aspectFill"></image>
            </block>
          </view>
        </block>
        <view class="post-meta">
          <view class="post-date">{{item.formattedDate}}</view>
          <button class="delete-btn" size="mini"  data-id="{{item._id}}" bindtap="deletePost">删除</button>
        </view>
      </view>
    </view>
  </block>
  <block wx:else>
    <view class="empty-container">
      <view class="empty-text">您还没有发表任何帖子</view>
    </view>
  </block>
</view>
