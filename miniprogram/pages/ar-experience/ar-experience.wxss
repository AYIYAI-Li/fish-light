.page-container {
  padding: 0;
  padding-bottom: 80px;
  background-color: #FFFBF2;
}


.top-background {
  position: relative;
  width: 100%;
  height: 130px;
  overflow: hidden;
  border-radius: 5px;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
}

.background-title {
  font-size: 28px;
  font-weight: 600;
  color: white;
  margin-bottom: 8px;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

.background-subtitle {
  font-size: 16px;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1px 2px rgba(0,0,0,0.5);
}

/* 标签页切换 */
.tabs-container {
  display: flex;
  background: #FFFCF7;
  border-radius: 16px;
  margin: 20px;
  padding: 6px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.tab-item {
  flex: 1;
  padding: 12px;
  text-align: center;
  border-radius: 12px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.tab-item.active {
  background: #CFB882;
  box-shadow: 0 2px 8px rgba(207, 184, 130, 0.3);
}

.tab-text {
  font-size: 15px;
  font-weight: 500;
  color: #1a1a1a;
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: 600;
}

/* 内容区域 */
.content-section {
  padding: 0 20px;
}

/* 制作步骤网格 */
.steps-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-top: 20px;
}

.step-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  cursor: pointer;
  transition: all 0.3s ease;
}

.step-card:active {
  transform: scale(0.98);
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}

.step-image {
  width: 100%;
  height: 150px;
  display: block;
}

.step-info {
  padding: 12px;
}

.step-number {
  font-size: 12px;
  color: #CFB882;
  font-weight: 600;
  margin-bottom: 4px;
}

.step-title {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
}

/* AR海报网格 - 六个格子布局 */
.posters-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15px;
  margin-top: 20px;
  padding-bottom: 20px;
}

.poster-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  min-height: 450px;
}

.poster-card:active {
  transform: scale(0.98);
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}

.poster-qr {
  width: 100%;
  height: 120px;
  background: #f8f9fa;
  padding: 10px;
  display: block;
  flex-shrink: 0;
  cursor: pointer;
  box-sizing: border-box;
}

.poster-qr:active {
  opacity: 0.8;
}

.poster-image {
  width: 100%;
  height: 200px;
  display: block;
  flex-shrink: 0;
  cursor: pointer;
  position: relative;
  z-index: 1;
}

.poster-image:active {
  opacity: 0.8;
}

.poster-video-wrapper {
  width: 100%;
  height: 120px;
  flex-shrink: 0;
  position: relative;
  background: #000;
  overflow: hidden;
}

.poster-video {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: contain;
}

.poster-info {
  padding: 12px;
  text-align: center;
  background: #fff;
  flex-shrink: 0;
}

.poster-title {
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
}

/* 长按操作弹窗 */
.action-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.action-modal-content {
  background: #fff;
  border-radius: 16px;
  width: 80%;
  max-width: 300px;
  overflow: hidden;
}

.action-modal-title {
  padding: 16px;
  text-align: center;
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  border-bottom: 1px solid #f0f0f0;
}

.action-item {
  padding: 14px 16px;
  text-align: center;
  border-bottom: 1px solid #f0f0f0;
  cursor: pointer;
  transition: background 0.2s;
}

.action-item:active {
  background: #f5f5f5;
}

.action-item:last-child {
  border-bottom: none;
}

.action-text {
  font-size: 15px;
  color: #1a1a1a;
}

.action-text.cancel {
  color: #999;
}