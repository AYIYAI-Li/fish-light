.page-container {
  padding: 20px;
  padding-bottom: 80px;
  background-color: #FEFCF0;
}
.page-header {
  margin-bottom: 24px;
  text-align: center;
}
.page-title {
  font-size: 24px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8px;
}
.page-subtitle {
  font-size: 14px;
  color: #666;
  display: block;
}

/* 发布动态卡片 */
.publish-card {
  background: #FAF4E8;
  border-radius: 25px;
  border: #D2B083 solid;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  padding: 16px 0 16px 0;
  margin: 0 auto 32px auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  transition: box-shadow 0.2s;
  width: 85vw;
  max-width: 400px;
}
.publish-card:active {
  box-shadow: 0 4px 16px rgba(0,0,0,0.10);
}
.publish-icon {
  font-size: 40px;
  margin-bottom: 8px;
}
.publish-title {
  font-size: 20px;
  font-weight: bold;
  color: #222;
  margin-bottom: 6px;
}
.publish-desc {
  font-size: 14px;
  color: #888;
}

.posts-section {
  background: #FFFBF2;
  border: #D1BF9B solid;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  width: 4px;
  height: 18px;
  background: #CDB285;
  margin-right: 12px;
  border-radius: 2px;
}
.post-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.post-item {
  background: #FFFBF2;
  padding: 20px;
  transition: all 0.3s ease;
}
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}
.user-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 12px;
  object-fit: cover;
}
.user-info text {
  display: block;
}
.post-content {
  margin-bottom: 16px;
}
.post-text {
  font-size: 14px;
  color: #1a1a1a;
  line-height: 1.6;
  margin-bottom: 12px;
}
.post-actions {
  display: flex;
  gap: 24px;
  justify-content: flex-end;
}
.post-action {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #666;
  cursor: pointer;
  transition: color 0.2s ease;
}
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}
.post-image {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  object-fit: cover;
  background: #f0f0f0;
}

/* 评论区 */
.comment-list {
  margin-top: 4px;
  padding-left: 8px;
  border-left: 2px solid #F5F1E6;
  background: #FFFBF2;
  border-radius: 6px;
  padding-top: 1px;
  padding-bottom: 6px;
}
.comment-item {
  margin-bottom: 4px;
  padding: 5px 0;
  border-bottom: 1px solid #FFFBF2;
}
.reply-item {
  margin-left: 1px;
  background: #FFFBF2;
}
.comment-main text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
  font-size: 12px;
}
.comment-user {
  color: #1a73e8;
  margin-right: 4px;
}
.comment-meta-row {
  display: flex;
  align-items: center;
  font-size: 12px;
  color: #aaa;
  margin-left: 0;
  justify-content: space-between;
}
.comment-actions-right {
  display: flex;
  gap: 4px;
}
.comment-action-btn {
  color: #444;
  background: #FFFBF2;
  padding: 0 8px;
  cursor: pointer;
  display: inline;
}
.comment-action-btn:active {
  color: #D1A777;
}
.comment-time {
  color: #aaa;
  font-size: 12px;
}

/* 发布动态弹窗 */
.post-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  z-index: 1000;
  padding-top: 40px;
}
.post-modal-content {
  background: #FFFBF2;
  border-radius: 16px;
  width: 70vw;
  max-width: 320px;
  padding: 24px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.post-modal-header {
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8px;
}
.post-textarea {
  width: 90%;
  height: 80px;
  border: 1px solid #D3B581;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  resize: vertical;
  display: block;       
  margin-left: auto;     
  margin-right: auto;    
}
.image-upload {
  display: flex;
  align-items: center;
  gap: 12px;
}
.upload-btn {
  background: #f8f9fa;
  color: #666;
  border: 1px solid #D3B581;
  padding: 6px 16px;
  font-size: 14px;
  cursor: pointer;
}
.preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}
.preview-item {
  position: relative;
  width: 60px;
  height: 60px;
  border-radius: 8px;
  overflow: hidden;
  background: #f0f0f0;
}
.preview-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
}
.remove-image {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 18px;
  height: 18px;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 18px;
  font-size: 12px;
  cursor: pointer;
  z-index: 2;
}
.post-modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
}
.cancel-btn {
  background: #f8f9fa;
  color: #666;
  border: #D3B581 solid 1px;
  padding: 8px 18px;
  font-size: 14px;
}
.submit-btn {
  background: #D3B581;
  color: #666;
  border: none;
  padding: 8px 18px;
  font-size: 14px;
  font-weight: 500;
}

/* 评论弹窗 */
.comment-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}
.comment-modal-content {
  background: #fff;
  border-radius: 16px;
  width: 80vw;
  max-width: 300px;
  padding: 24px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.comment-modal-header {
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8px;
}
.comment-textarea {
  width: 90%;            /* 缩小宽度 */
  min-height: 60px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  resize: vertical;
  outline: none;
  margin-left: auto;     /* 左右自动外边距 */
  margin-right: auto;    /* 使其水平居中 */
  display: block;        /* 设为块级元素 */
}
.comment-modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
}

/* 交流群 */
.groups-section {
  background: #F5F1E5;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.groups-grid {
  display: flex;
  justify-content: center;
  gap: 16px;
}
.group-card {
  background: #E9D5BD;
  border-radius: 0px;
  padding: 20px;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 300px;
  margin: 0 auto;
}
.group-title {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8px;
  text-align: center;
}
.group-desc {
  font-size: 13px;
  color: #666;
  margin-bottom: 12px;
}

/* 交流群弹窗 */
.group-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3000;
}
.group-modal-content {
  background: #FFFBF2;
  width: 80vw;
  max-width: 320px;
  padding: 32px 20px 20px 20px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.group-modal-title {
  font-size: 20px;
  font-weight: bold;
  margin-bottom: 8px;
  text-align: center;
}
.group-modal-desc {
  font-size: 15px;
  color: #666;
  margin-bottom: 16px;
  text-align: center;
}
.group-modal-qq {
  font-size: 16px;
  color: black;
  margin-bottom: 20px;
  text-align: center;
}
.group-modal-qq {
  font-size: 16px;
  color: black;
  margin-bottom: 20px;
}
.group-modal-actions {
  width: 100%;
  display: flex;
  justify-content: center;
}
.group-modal-close {
  background: #CDB285;
  color: #333;
  border: none;
  padding: 8px 24px;
  font-size: 15px;
}
