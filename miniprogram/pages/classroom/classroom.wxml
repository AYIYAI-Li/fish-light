<view class="page-container">
  <view class="top-background">
    <image src="/images/background.png" class="background-image" mode="aspectFill"></image>
    <view class="background-overlay">
      <text class="background-title">非遗课堂</text>
      <text class="background-subtitle">制作过程视频与快问快答</text>
    </view>
  </view>
  

  <view class="main-content">
    <view class="category-tabs">
      <view
        class="category-tab {{activeSection === 'making' ? 'active' : ''}}"
        data-section="making"
        bindtap="onSectionTap"
      >制作过程</view>
      <view
        class="category-tab {{activeSection === 'qa' ? 'active' : ''}}"
        data-section="qa"
        bindtap="onSectionTap"
      >快问快答</view>
    </view>

    <!-- 制作过程视频 -->
    <view wx:if="{{activeSection === 'making'}}" class="video-section">
      <view class="section-title">制作过程视频</view>
      <view class="video-list">
        <block wx:for="{{makingVideos}}" wx:key="title" wx:for-item="video">
          <view class="video-item {{video.isFull ? 'full-process' : ''}}">
            <video
              id="video-making-{{index}}"
              src="{{video.videoUrl}}"
              controls
              bindplay="onVideoPlay"
              binderror="onVideoError"
              data-index="{{index}}"
              data-section="making"
              class="video-player"
              show-center-play-btn="true"
              enable-progress-gesture="true"
              style="width: 100%; height: 178px; border-radius: 8px; background: #000;"
            ></video>
            <view class="video-info">
              <view class="video-title">
                <text wx:if="{{video.isFull}}" class="process-badge">全过程</text>
                <text wx:if="{{video.step}}" class="step-badge">步骤{{video.step}}</text>
                {{video.title}}
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 快问快答视频 -->
    <view wx:if="{{activeSection === 'qa'}}" class="video-section">
      <view class="section-title">快问快答</view>
      <view class="video-list">
        <block wx:for="{{qaVideos}}" wx:key="title" wx:for-item="video">
          <view class="video-item">
            <video
              id="video-qa-{{index}}"
              src="{{video.videoUrl}}"
              controls
              bindplay="onVideoPlay"
              binderror="onVideoError"
              data-index="{{index}}"
              data-section="qa"
              class="video-player"
              show-center-play-btn="true"
              enable-progress-gesture="true"
              style="width: 100%; height: 178px; border-radius: 8px; background: #000;"
            ></video>
            <view class="video-info">
              <view class="video-title">
                <text class="qa-badge">Q{{video.question}}</text>
                {{video.title}}
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
  

  <tabbar current="classroom"></tabbar>
</view>