<view class="page-container">
  <view class="top-background">
    <image src="cloud://cloud1-4g4nzi8a994f009b.636c-cloud1-4g4nzi8a994f009b-1411647226/icon/background.png" class="background-image" mode="aspectFill"></image>
    <view class="background-overlay">
      <text class="background-title">鱼灯制作</text>
      <text class="background-subtitle">按顺序选择组件，逐步完成鱼灯组合</text>
    </view>
  </view>

  <view class="content-section">
    <view class="panel-card">
      <view class="section-title">组件选择</view>
      <view class="section-desc">拖动组件至下方区域，完成鱼灯的制作</view>
      <view class="components-grid">
        <block wx:for="{{components}}" wx:key="name">
          <view
            class="component-card {{item.step < nextStepIndex ? 'completed' : ''}}"
            data-step="{{item.step}}"
            data-image="{{item.componentImage}}"
            data-drag-width="{{item.dragWidth}}"
            data-drag-height="{{item.dragHeight}}"
            bindtouchstart="onComponentTouchStart"
            catchtouchmove="onComponentTouchMove"
            bindtouchend="onComponentTouchEnd"
          >
            <image src="{{item.componentImage}}" class="component-image" mode="aspectFit"></image>
            <view class="component-name">{{item.name}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-title">组合展示</view>
      <view class="assemble-box" style="min-height: {{finished ? '700rpx' : '520rpx'}};">
        <block wx:if="{{currentResult}}">
          <view class="result-card">
            <image
              src="{{currentResult.image}}"
              class="result-image"
              mode="aspectFill"
              style="width: {{currentResult.width}}; height: {{currentResult.height}}; margin-top: {{currentResult.offsetTop}}; margin-left: {{currentResult.offsetLeft}};"
            ></image>
          </view>
          <view wx:if="{{finished}}" class="finish-tip">
            <text class="finish-text">恭喜你已完成鱼灯的制作
            点击“重置”可以重新制作</text>
            <view class="reset-btn" bindtap="onResetTap">重置</view>
          </view>
        </block>
        <view wx:else class="empty-state">
          <text class="empty-title">等待开始制作</text>
          <text class="empty-desc"></text>
        </view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{dragging}}"
    class="drag-preview"
    style="left: {{dragX}}px; top: {{dragY}}px; width: {{dragWidth}}; height: {{dragHeight}};"
  >
    <image src="{{dragImage}}" class="drag-image" mode="aspectFit"></image>
  </view>

  <tabbar current="fish-making"></tabbar>
</view>