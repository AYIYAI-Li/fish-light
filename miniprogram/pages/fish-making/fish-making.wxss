.page-container {
  min-height: 100vh;
  padding-bottom: 80px;
  background-color: #FFFBF2;
}

.top-background {
  position: relative;
  width: 100%;
  height: 130px;
  overflow: hidden;
  border-radius: 5px;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.6));
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
}

.background-title {
  font-size: 28px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8px;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
}

.background-subtitle {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
}

.content-section {
  padding: 20px;
}

.panel-card {
  background: #FFFCF7;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 4px;
  height: 18px;
  background: #CFB882;
  border-radius: 2px;
  margin-right: 12px;
}

.section-desc {
  font-size: 13px;
  line-height: 1.6;
  color: #7A6A4F;
  margin-bottom: 16px;
}

.components-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-row-gap: 12px;
  grid-column-gap: 12px;
}

.component-card {
  position: relative;
  width: 100%;
  min-height: 192rpx;
  padding: 18rpx 16rpx 20rpx;
  border-radius: 14px;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.component-card.active {
  border-color: #CFB882;
  box-shadow: 0 8px 20px rgba(207, 184, 130, 0.18);
}

.component-card.completed {
  background: #F8F2E4;
}

.component-order {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  min-width: 34rpx;
  height: 34rpx;
  border-radius: 17rpx;
  background: #CFB882;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.component-image {
  width: 92rpx;
  height: 92rpx;
  margin-bottom: 16rpx;
}

.component-name {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 600;
  line-height: 1.4;
}

.assemble-box {
  min-height: 520rpx;
  border: 3rpx dashed #CFB882;
  border-radius: 16px;
  background: #FFF9EE;
  padding: 20px;
  box-sizing: border-box;
}

.result-card {
  background: #fff;
  border-radius: 14px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.result-card + .result-card {
  margin-top: 16px;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.result-step {
  font-size: 12px;
  color: #CFB882;
  font-weight: 600;
}

.result-title {
  font-size: 14px;
  color: #1a1a1a;
  font-weight: 600;
}

.result-image {
  width: 100%;
  display: block;
}

.finish-tip {
  margin-top: 16px;
  text-align: center;
}

.finish-text {
  display: block;
  font-size: 13px;
  line-height: 1.7;
  color: #7A6A4F;
  margin-bottom: 12px;
}

.reset-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 24px;
  border-radius: 999px;
  background: #CFB882;
  color: #fff;
  font-size: 14px;
}

.reset-btn:active {
  opacity: 0.8;
}

.empty-state {
  min-height: 440rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  color: #8A7A5E;
}

.empty-title {
  font-size: 16px;
  font-weight: 600;
  color: #7A6A4F;
  margin-bottom: 10px;
}

.empty-desc {
  font-size: 13px;
  line-height: 1.7;
}

.drag-preview {
  position: fixed;
  z-index: 9999;
  pointer-events: none;
  transform: translate(-50%, -50%);
}

.drag-image {
  width: 100%;
  height: 100%;
  display: block;
}
