.page-container {
  padding: 0;
  background: #FFFBF2;
  min-height: 100vh;
}

.top-background {
  position: relative;
  width: 100%;
  height: 130px;
  overflow: hidden;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
}

.background-title {
  font-size: 28px;
  font-weight: 600;
  color: white;
  margin-bottom: 8px;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

.background-subtitle {
  font-size: 16px;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1px 2px rgba(0,0,0,0.5);
}


.main-content {
  padding: 20px;
}

.page-header {
  text-align: center;
  margin-bottom: 30px;
}

.page-title {
  font-size: 28px;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8px;
}

.page-subtitle {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
}


.contact-info-section {
  background: #F8F4E9;
  border: #D4CBA4 solid;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.section-title {
  font-size: 20px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 4px;
  height: 20px;
  background: #D4CBA4;
  margin-right: 12px;
  border-radius: 2px;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 24px;
  margin-right: 16px;
  width: 40px;
  text-align: center;
}

.contact-content {
  flex: 1;
}

.contact-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 4px;
}

.contact-value {
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 4px;
}


.tips-section {
  background: #F8F4E9;
  border: #D4CBA4 solid;
  border-radius: 16px;
  padding: 24px;
  margin-top: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.tips-content {
  color: #666;
  line-height: 1.6;
}

.tip-item {
  margin-bottom: 8px;
  font-size: 14px;
  padding-left: 20px;
  text-indent: -20px;
}

.tip-item:last-child {
  margin-bottom: 0;
}


@media (max-width: 375px) {
  .main-content {
    padding: 16px;
  }
  
  .contact-info-section,
  .tips-section {
    padding: 20px;
  }
  
  .background-title {
    font-size: 24px;
  }
}
