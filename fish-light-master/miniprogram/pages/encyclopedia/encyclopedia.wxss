.page-container {
  padding: 0;
  background: #FFFBF2;
  min-height: 100vh;
  box-sizing: border-box;
}


.top-background {
  position: relative;
  width: 100%;
  height: 130px;
  overflow: hidden;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
}

.background-title {
  font-size: 28px;
  font-weight: 600;
  color: white;
  margin-bottom: 8px;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

.background-subtitle {
  font-size: 16px;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1px 2px rgba(0,0,0,0.5);
}


.main-content {
  padding: 20px;
}

.page-header {
  text-align: center;
  padding: 20px;
  background: #F8F4E9;
  margin-bottom: 10px;
}

.page-title {
  font-size: 24px;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8px;
}

.page-subtitle {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
}

.articles-section {
  padding: 0;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 15px;
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
}

.title-text {
  flex: 1;
}

.article-count {
  font-size: 13px;
  color: #666;
  font-weight: normal;
}

.articles-list {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.article-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}


.article-visual {
  position: relative;
  height: 200px;
  overflow: hidden;
}

.article-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}


.content-card {
  padding: 20px;
  background: #F8F4E9;
  border: #C3AD7E solid;
}

.article-title {
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 10px;
  line-height: 1.4;
}

.article-summary {
  font-size: 14px;
  color: #333;
  margin-bottom: 12px;
  line-height: 1.5;
}

.article-content {
  font-size: 13px;
  color: #666;
  line-height: 1.6;
}

