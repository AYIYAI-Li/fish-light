.page-container {
  padding: 0;
  padding-bottom: 80px;
  background: #FFFBF2;
  min-height: 100vh;
}


.top-background {
  position: relative;
  width: 100%;
  height: 130px;
  overflow: hidden;
  border-radius: 5px;
}

.background-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
}

.background-title {
  font-size: 28px;
  font-weight: 600;
  color: white;
  margin-bottom: 8px;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

.background-subtitle {
  font-size: 16px;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1px 2px rgba(0,0,0,0.5);
}


.main-content {
  padding: 20px;
}

/* 页面头部 */
.page-header {
  margin-bottom: 24px;
}
.page-title {
  font-size: 24px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8px;
  display: block;
}
.page-subtitle {
  font-size: 14px;
  color: #666;
  display: block;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  background: #FFFCF7;
  border-radius: 12px;
  padding: 4px;
  margin-bottom: 24px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.category-tab {
  flex: 1;
  padding: 12px 0;
  text-align: center;
  border-radius: 0px;
  font-size: 14px;
  font-weight: 500;
  color: #666;
  transition: all 0.3s;
  background: transparent;
  border: none;
  outline: none;
  position: relative;
}
.category-tab.active {
  background: #CFB47D;
  color: #fff;
  box-shadow: 0 2px 8px rgba(26,115,232,0.08);
}
.category-tab:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 25%;
  width: 1px;
  height: 50%;
  background: #e0e0e0;
}

/* 视频列表 */
.video-section {
  background: #F8F4E9;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  width: 4px;
  height: 18px;
  background: #CFB47D;
  margin-right: 12px;
  border-radius: 2px;
  display: inline-block;
}
.video-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.video-item {
  display: flex;
  flex-direction: column;
  background: #F8F4E9;
  border-radius: 0px;
  padding: 16px;
  transition: all 0.3s;
  border: 2px solid transparent;
  margin-bottom: 0;
}
.video-item.full-process {
  border: 2px solid #CFB47D;
  background: #FFFBF2;
}
.video-player {
  width: 100%;
  height: 178px;
  border-radius: 8px;
  background: linear-gradient(135deg, #CFB47D);
  margin-bottom: 12px;
}
.video-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.video-title {
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 4px;
  line-height: 1.4;
  display: flex;
  align-items: center;
  gap: 8px;
}
.video-meta {
  display: flex;
  align-items: center;
  font-size: 13px;
  color: #666;
}
.video-category {
  background: #CFB47D;
  color: white;
  padding: 2px 8px;
  border-radius: 0px;
  font-size: 12px;
  font-weight: 500;
  margin-left: 0;
}

/* 徽章样式 */
.process-badge {
  background: #CFB47D;
  color: white;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
}
.step-badge {
  background: #8B7355;
  color: white;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
}
.qa-badge {
  background: #E8B86D;
  color: white;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
}