.page-container {
  background-color: #F4F0E4;
  min-height: 100vh;
  position: relative;
}

/* 加载状态样式 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #D1A777;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 登录弹窗样式 */
.first-login-dialog {
  background: white;
  border-radius: 16rpx;
  width: 600rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.dialog-content {
  margin-bottom: 40rpx;
  text-align: center;
}

.dialog-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.2;
}

.dialog-actions {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.dialog-actions .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx; 
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 0 15rpx;
  padding: 0;
  display: flex;
  align-items: center; 
  justify-content: center; 
}

.dialog-actions .cancel {
  background: #f5f5f5;
  color: #333;
}

.dialog-actions .confirm {
  background: #D1A777;
  color: white;
}
.arrow-icon {
  color: #999;
  font-size: 32rpx;
  margin-left: 10rpx;
}

/* 弹窗遮罩 */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

/* 用户信息 */
.profile-section {
  position: relative;
  padding-bottom: 20rpx;
  color: var(--text-color-primary);
}

.profile-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 100rpx 40rpx 0;
}

.profile-content .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.info-text {
  flex: 1;
  margin-left: 30rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.login-status {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.login-hint {
  margin-top: 8rpx;
}

.hint-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-style: italic;
}

.settings-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.settings-icon {
  width: 36rpx;
  height: 36rpx;
}



/* 卡片通用样式 */
.card-section {
  background-color: #E7E0D0;
  margin: 24rpx 24rpx 0;
  padding: 20rpx;
  background-size: 100% 100%;
  background-repeat: no-repeat;
}

/* 网格菜单 */
.grid-menu {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.grid-item .item-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 16rpx;
}

.grid-item .item-title {
  font-size: 24rpx;
  color: var(--text-color-primary);
}

/* 列表菜单 */
.list-card {
  padding: 10rpx 20rpx;
  background-color: #E7E0D0;
}

.list-menu {
  display: flex;
  flex-direction: column;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 10rpx;
  border-bottom: 1rpx solid #f5f1ed;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item .item-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
}

.list-item .item-title {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color-primary);
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 编辑资料对话框 */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  width: 640rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.dialog-title {
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.dialog-body {
  padding: 16rpx 32rpx 0;
}

.avatar-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar.large {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 0, 0, 0.06);
  margin-bottom: 16rpx;
}

.avatar-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.avatar-btn {
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
  background: #D1A777;
  color: #fff;
}

.nickname-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nickname-input {
  padding: 20rpx 24rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  font-size: 28rpx;
}



.dialog-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
}

.btn {
  min-width: 160rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn.cancel {
  background: #eee;
  color: #333;
}

.btn.confirm {
  background: #D1A777;
  color: #fff;
}

/* 退出登录按钮 */
.logout-card {
  background-color: transparent;
  box-shadow: none;
  padding: 0;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #D1A777;
  border: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.logout-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.4);
}



.logout-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.logout-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  line-height: 1.4;
}